rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rudyendo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.brand is string && data.brand.size() > 0 &&
               data.price is number && data.price >= 0 &&
               data.category is string &&
               data.imageUrl is string &&
               (data.get('isVisible', true) is bool);
      }

      allow read: if true; // Public catalog
      
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isAdmin() && isValidProduct(incoming());
      
      allow delete: if isAdmin();

      // Reviews Subcollection
      match /reviews/{reviewId} {
        function isValidReview(data) {
          return data.user is string && data.user.size() > 0 &&
                 data.rating is number && data.rating >= 1 && data.rating <= 5 &&
                 data.comment is string && data.comment.size() <= 1000 &&
                 data.date is string;
        }

        allow read: if true;
        allow create: if true; // Any user can leave a review
        allow update, delete: if isAdmin();
      }
    }

    // Admins Collection (to allow self-registration or manual promotion)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console or bootstrap
    }
    
    // Test collection for setup tool
    match /test/connection {
      allow read: if true;
    }
  }
}
