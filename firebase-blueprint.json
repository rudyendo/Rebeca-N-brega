{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Hair product sold at the salon",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "ebookUrl": { "type": "string" },
        "details": { "type": "string" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["name", "line", "category", "price", "imageUrl"]
    },
    "Line": {
      "title": "Product Line",
      "description": "High level grouping for products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Technical grouping for products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of hair products"
    },
    "/lines/{lineId}": {
      "schema": "Line",
      "description": "Collection of product lines"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    }
  }
}
